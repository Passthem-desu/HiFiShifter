{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "HiFiShifter",
    "version": "1.0.0",
    "identifier": "com.arounder.hifishifter",
    "build": {
        "beforeDevCommand": "npm --prefix ../frontend run build",
        "beforeBuildCommand": "npm --prefix ../frontend run build",
        "frontendDist": "../../frontend/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "HiFiShifter",
                "width": 800,
                "height": 600,
                "visible": true,
                "dragDropEnabled": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "nsis"
        ],
        "windows": {
            "nsis": {
                "installMode": "both"
            }
        },
        "resources": {
            "resources/models/nsf_hifigan/pc_nsf_hifigan.onnx": "models/nsf_hifigan/pc_nsf_hifigan.onnx",
            "resources/models/nsf_hifigan/config.json": "models/nsf_hifigan/config.json"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}